{
  "name": "@acahet/playwright-reporter",
  "version": "0.0.3",
  "description": "Self-hosted Playwright test history dashboard — custom reporter + single-file HTML dashboard. No SaaS, no subscriptions.",
  "main": "dist/src/reporter.js",
  "types": "dist/src/reporter.d.ts",
  "exports": {
    "./reporter": {
      "require": "./dist/src/reporter.js",
      "import": "./dist/src/reporter.js",
      "types": "./dist/src/reporter.d.ts"
    }
  },
  "files": [
    "dist/",
    "dashboard/"
  ],
  "dependencies": {
    "serve": "^14.2.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.42.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "playwright",
    "reporter",
    "dashboard",
    "test-history"
  ],
  "author": "acahet",
  "license": "MIT"
}
