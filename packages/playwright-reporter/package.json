{
  "name": "@acahet/playwright-reporter",
  "version": "0.1.4",
  "main": "dist/src/reporter.js",
  "description": "Self-hosted Playwright test history dashboard — custom reporter + single-file HTML dashboard. No SaaS, no subscriptions.",
  "types": "dist/src/reporter.d.ts",
  "exports": {
    ".": "./dist/src/reporter.js",
    "./reporter": "./dist/src/reporter.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "dashboard/"
  ],
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "serve": "^14.2.6",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.42.0"
  },
  "keywords": [
    "playwright",
    "reporter",
    "dashboard",
    "test-history"
