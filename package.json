{
  "name": "@acahet/pw-standard",
  "version": "1.0.0",
  "description": "Shared Playwright + TypeScript standards: ESLint rules, configs, base classes and fixtures",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./eslint": {
      "import": "./dist/eslint/index.js",
      "require": "./dist/eslint/index.js",
      "types": "./dist/eslint/index.d.ts"
    },
    "./playwright": {
      "import": "./dist/playwright/index.js",
      "require": "./dist/playwright/index.js",
      "types": "./dist/playwright/index.d.ts"
    },
    "./tsconfig/base": "./src/tsconfig/base.json",
    "./tsconfig/strict": "./src/tsconfig/strict.json",
    "./base": {
      "import": "./dist/base/index.js",
      "require": "./dist/base/index.js",
      "types": "./dist/base/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/tsconfig",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "playwright",
    "typescript",
    "testing",
    "e2e",
    "standards"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "eslint": ">=8.0.0",
    "@playwright/test": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/eslint": "^8.56.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
